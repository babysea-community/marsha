# ============================================================================
# Marsha
# Every output becomes the next input.
#
# First deploy tip:
# - Keep the default stack until your first build works
# - Fill required values only
# - Leave optional fields blank until you intentionally choose to use them
# - Never commit real secret values to Git
# ============================================================================

# ----------------------------------------------------------------------------
# CONFIG
# ----------------------------------------------------------------------------

# The exact URL where the app runs
# Local development: http://localhost:3011
# Production (your custom domain): https://your-domain.example.com
NEXT_PUBLIC_SITE_URL=

# Single-user access (only this email can enter the dashboard)
OWNER_EMAIL=
OWNER_PASSWORD=

# Session cookie signing key (HS256)
# Generate strong secret with: openssl rand -hex 32
OWNER_SESSION_SECRET=

# ----------------------------------------------------------------------------
# DATABASE
# ----------------------------------------------------------------------------

# Default: aurora
# Allowed: aurora, polardb
# Both are PostgreSQL and share the same schema.
APP_DATABASE=aurora

# Apply schema after setting this: `pnpm run db:migrate`
# (applies the same schema whether APP_DATABASE is aurora or polardb)
# Include ?sslmode=require so the connection uses TLS
# Aurora: postgresql://USER:PASSWORD@CLUSTER.cluster-xxxxxxxxxxxx.REGION.rds.amazonaws.com:5432/postgres?sslmode=require
# PolarDB: postgresql://USER:PASSWORD@CLUSTER.cluster-xxxxxxxxxxxx.REGION.rds.aliyuncs.com:5432/postgres?sslmode=require
DATABASE_URL=

# ----------------------------------------------------------------------------
# APP
# ----------------------------------------------------------------------------

# Generate strong secret with: openssl rand -hex 32
APP_API_KEY=
APP_CRON_SECRET=
APP_CALLBACK_SECRET=

# ----------------------------------------------------------------------------
# INFERENCE
# ----------------------------------------------------------------------------

# Default: byok
# Allowed: byok, babysea
APP_PROVIDER_MODE=byok

# Default deployments use APP_PROVIDER_MODE=byok
# Fill inference keys below
# In most use cases, you need more than 1 inference to support all steps

# Alibaba Cloud
# Learn: https://www.alibabacloud.com/help/en/model-studio
# Uses the `singapore` region as global endpoint
DASHSCOPE_API_KEY=

# Black Forest Labs
# Learn: https://docs.bfl.ml
# Change BFL_REGION and BFL_API_BASE_URL if you're using a different region
BFL_API_KEY=
BFL_REGION=global
BFL_API_BASE_URL=https://api.bfl.ai/v1

# BytePlus
# Learn: https://docs.byteplus.com
# Uses the `ap-southeast` region because it supports all models
ARK_API_KEY=

# Google
# Learn: https://ai.google.dev/gemini-api/docs
GEMINI_API_KEY=

# OpenAI
# Learn: https://developers.openai.com/api/docs/guides/image-generation
OPENAI_API_KEY=

# Runway
# Learn: https://docs.dev.runwayml.com
RUNWAYML_API_SECRET=

# If APP_PROVIDER_MODE=babysea, fill the value below
# BabySea mode uses one BabySea key for supported image+video chain steps

# BabySea
# Learn: https://docs.babysea.ai
# Change BABYSEA_REGION and BABYSEA_API_BASE_URL if you're using a different region
BABYSEA_API_KEY=
BABYSEA_REGION=us
BABYSEA_API_BASE_URL=https://api.us.babysea.ai
BABYSEA_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# AGENTIC WORKFLOW (optional)
# ----------------------------------------------------------------------------

# Required for Agentic Workflow modes: Copilot/Autopilot
# Change AGENT_CHAIN_AWS_BEDROCK_REGION and AGENT_CHAIN_AWS_BEDROCK_AGENT if you're using a different region
AGENT_CHAIN_AWS_BEDROCK_TOKEN=
AGENT_CHAIN_AWS_BEDROCK_REGION=us-east-1
AGENT_CHAIN_AWS_BEDROCK_AGENT=us.amazon.nova-2-lite-v1:0

# ----------------------------------------------------------------------------
# STORAGE (optional)
# ----------------------------------------------------------------------------

# Default: none
# Allowed: none, alibaba-cloud-oss, aws-s3, backblaze-b2, cloudflare-r2, huggingface-storage-buckets, minio, scaleway-object-storage, spaces-object-storage, vercel-blob
# When enabled, the app copies completed step outputs to your
# storage provider and stores those durable URLs in output_files
APP_STORAGE_PROVIDER=none

# Fill these only if APP_STORAGE_PROVIDER=alibaba-cloud-oss
# - ALIBABA_CLOUD_OSS_ENDPOINT is optional; set it to force a specific OSS endpoint host
# - ALIBABA_CLOUD_OSS_PUBLIC_BASE_URL is optional; set it to serve media from a CDN or custom domain
ALIBABA_CLOUD_OSS_REGION=
ALIBABA_CLOUD_OSS_ACCESS_KEY_ID=
ALIBABA_CLOUD_OSS_ACCESS_KEY_SECRET=
ALIBABA_CLOUD_OSS_BUCKET_NAME=
ALIBABA_CLOUD_OSS_ENDPOINT=
ALIBABA_CLOUD_OSS_PUBLIC_BASE_URL=

# Fill these only if APP_STORAGE_PROVIDER=aws-s3
# - AWS_S3_ENDPOINT_URL is the browser-readable image base URL, preferably CloudFront or a custom domain
#   Example: https://your-cloudfront-domain or https://your-media-domain
AWS_S3_REGION=
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=

# Fill these only if APP_STORAGE_PROVIDER=backblaze-b2
# - No public bucket URL or S3 endpoint is required; app uses the native B2 API and signed download URLs
BACKBLAZE_B2_KEY_ID=
BACKBLAZE_B2_APPLICATION_KEY=
BACKBLAZE_B2_BUCKET_NAME=

# Fill these only if APP_STORAGE_PROVIDER=cloudflare-r2
# - CLOUDFLARE_R2_ENDPOINT_URL is your `S3 API` url, example: https://your-r2-account-id.r2-region.r2.cloudflarestorage.com/r2-bucket-name
# - CLOUDFLARE_R2_CUSTOM_DOMAIN_URL is your public read url, example: https://pub-token.r2.dev or https://your-storage.example.com
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_ENDPOINT_URL=
CLOUDFLARE_R2_CUSTOM_DOMAIN_URL=

# Fill these only if APP_STORAGE_PROVIDER=huggingface-storage-buckets
# - HUGGINGFACE_STORAGE_NAMESPACE is your Hugging Face username or organization
# - HUGGINGFACE_STORAGE_PUBLIC_BASE_URL is optional; set it for a public/custom media base URL
HUGGINGFACE_STORAGE_NAMESPACE=
HUGGINGFACE_STORAGE_ACCESS_KEY_ID=
HUGGINGFACE_STORAGE_SECRET_ACCESS_KEY=
HUGGINGFACE_STORAGE_BUCKET_NAME=
HUGGINGFACE_STORAGE_PUBLIC_BASE_URL=

# Fill these only if APP_STORAGE_PROVIDER=minio
# - MINIO_ENDPOINT_URL is your MinIO S3 API endpoint, e.g. https://minio.example.com
# - MINIO_REGION defaults to us-east-1 when blank
# - MINIO_PUBLIC_BASE_URL is optional; when blank, Marsha returns MINIO_ENDPOINT_URL/<bucket>/<key>
MINIO_ENDPOINT_URL=
MINIO_ACCESS_KEY_ID=
MINIO_SECRET_ACCESS_KEY=
MINIO_BUCKET_NAME=
MINIO_REGION=us-east-1
MINIO_PUBLIC_BASE_URL=

# Fill these only if APP_STORAGE_PROVIDER=scaleway-object-storage
# - SCALEWAY_OBJECT_STORAGE_REGION is the Scaleway region, e.g. fr-par
# - SCALEWAY_OBJECT_STORAGE_ENDPOINT_URL defaults to https://s3.<region>.scw.cloud
# - SCALEWAY_OBJECT_STORAGE_PUBLIC_BASE_URL defaults to https://<bucket>.s3.<region>.scw.cloud
SCALEWAY_OBJECT_STORAGE_REGION=
SCALEWAY_OBJECT_STORAGE_ACCESS_KEY_ID=
SCALEWAY_OBJECT_STORAGE_SECRET_ACCESS_KEY=
SCALEWAY_OBJECT_STORAGE_BUCKET_NAME=
SCALEWAY_OBJECT_STORAGE_ENDPOINT_URL=
SCALEWAY_OBJECT_STORAGE_PUBLIC_BASE_URL=

# Fill these only if APP_STORAGE_PROVIDER=spaces-object-storage
# - SPACES_REGION is the DigitalOcean Spaces region, e.g. nyc3
# - SPACES_ENDPOINT_URL defaults to https://<region>.digitaloceanspaces.com
# - SPACES_PUBLIC_BASE_URL defaults to https://<bucket>.<region>.digitaloceanspaces.com
SPACES_REGION=
SPACES_ACCESS_KEY_ID=
SPACES_SECRET_ACCESS_KEY=
SPACES_BUCKET_NAME=
SPACES_ENDPOINT_URL=
SPACES_PUBLIC_BASE_URL=

# Fill this only if APP_STORAGE_PROVIDER=vercel-blob
BLOB_READ_WRITE_TOKEN=

# ----------------------------------------------------------------------------
# OBSERVABILITY (optional)
# ----------------------------------------------------------------------------

# Sentry
# Skip this for your first deploy unless you already use Sentry
# Learn: https://docs.sentry.io/platforms/javascript/guides/nextjs
# Sample rates (traces/replays) are hardcoded in (edit to tune):
# - `lib/monitoring/sentry-config.ts`
# - `instrumentation-client.ts`
# Leave blank to run without error tracking (the app no-ops cleanly)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=

# Required only to upload source maps at build time (never expose to client)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
