{
  "name": "marsha",
  "version": "0.1.0",
  "description": "AI studio for chaining generative media models and showrunner turning drama scenes into full stories.",
  "private": true,
  "license": "Apache-2.0",
  "homepage": "https://marsha.babysea.live",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/babysea-community/marsha.git"
  },
  "keywords": [
    "babysea",
    "open-source",
    "ai-infrastructure",
    "control-plane",
    "execution-layer",
    "inference-providers",
    "developer-tools",
    "creative-tools",
    "generative-ai",
    "generative-media"
  ],
  "engines": {
    "node": ">=24.14.0 <25"
  },
  "scripts": {
    "build": "next build",
    "clean": "git clean -xdf .next .turbo node_modules",
    "dev": "next dev --port=3011",
    "doctor": "node scripts/doctor.mjs",
    "db:migrate": "node scripts/db-migrate.mjs",
    "sentry:check": "node scripts/sentry-project-check.mjs",
    "format": "prettier --check \"**/*.{ts,tsx,css,md,json,jsonc,mjs}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,css,md,json,jsonc,mjs}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "next start",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "catalog:",
    "@aws-sdk/client-s3": "catalog:",
    "@radix-ui/react-slot": "catalog:",
    "@sentry/nextjs": "catalog:",
    "@vercel/blob": "catalog:",
    "@xyflow/react": "catalog:",
    "ali-oss": "catalog:",
    "babysea": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "jose": "catalog:",
    "next": "catalog:",
    "pg": "catalog:",
    "proxy-agent": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "semantic-lady": "catalog:",
    "server-only": "catalog:",
    "sonner": "catalog:",
    "tailwind-merge": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@next/eslint-plugin-next": "catalog:",
    "@tailwindcss/postcss": "catalog:",
    "@types/ali-oss": "catalog:",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "babel-plugin-react-compiler": "catalog:",
    "eslint": "catalog:",
    "eslint-config-next": "catalog:",
    "globals": "catalog:",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@11.7.0"
}
